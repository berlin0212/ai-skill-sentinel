{
    "version": "2.0.0",
    "last_updated": "2026-03-01",
    "description": "AI-Skill Sentinel 威胁情报数据库 v2 - 合并 ClawHavoc 特征 + 扩展行为检测",
    "critical_patterns": [
        {
            "id": "C01",
            "name": "提权尝试",
            "pattern": "sudo\\s|chmod\\s\\+s|visudo|chown\\sroot|setuid",
            "score": 40,
            "desc": "试图获取系统 Root 或持久化高权限。",
            "mitre": "T1548 - Abuse Elevation Control Mechanism"
        },
        {
            "id": "C02",
            "name": "反弹 Shell",
            "pattern": "nc\\s+-[elp]|/dev/tcp/|php\\s+-r.*fsockopen|bash\\s+-i\\s+>|mkfifo|mknod.*p",
            "score": 50,
            "desc": "典型的反弹 Shell 建立后门连接的行为。",
            "mitre": "T1059.004 - Unix Shell"
        },
        {
            "id": "C03",
            "name": "敏感路径扫描",
            "pattern": "/etc/shadow|/etc/passwd|\\.ssh/id_|authorized_keys|KeyChain|Login\\sData|Web\\sData|Cookies",
            "score": 40,
            "desc": "试图读取系统密码、SSH 密钥或浏览器保存的敏感凭据。",
            "mitre": "T1552.001 - Credentials In Files"
        },
        {
            "id": "C04",
            "name": "静默远程执行",
            "pattern": "curl.*\\|\\s*(bash|python|node|sh|perl|ruby)|wget.*\\|\\s*(bash|sh)",
            "score": 50,
            "desc": "从网络下载并直接在 Shell 中运行，绕过安全审查。",
            "mitre": "T1059.004 - Command and Scripting Interpreter"
        },
        {
            "id": "C05",
            "name": "Base64 隐藏载荷",
            "pattern": "base64\\s+(--)?decode|base64\\.b64decode|atob\\(|Buffer\\.from\\(.*base64",
            "score": 45,
            "desc": "使用 Base64 解码执行隐藏的恶意代码。",
            "mitre": "T1027 - Obfuscated Files or Information"
        },
        {
            "id": "C06",
            "name": "动态代码执行",
            "pattern": "eval\\(|exec\\(|compile\\(.*exec|Function\\(|new\\sFunction",
            "score": 35,
            "desc": "动态执行字符串代码，常见于混淆恶意脚本。",
            "mitre": "T1059 - Command and Scripting Interpreter"
        },
        {
            "id": "C07",
            "name": "已知恶意 C2 服务器 IP",
            "pattern": "91\\.92\\.242\\.30|185\\.196\\.8\\.|45\\.133\\.1\\.",
            "score": 50,
            "desc": "包含 ClawHavoc 攻击活动中已知的恶意控制服务器 IP 地址。",
            "mitre": "T1071 - Application Layer Protocol"
        },
        {
            "id": "C08",
            "name": "ClawHavoc 假安装包",
            "pattern": "(prerequisite|setup|installation).*download.*(openclaw-agent|openclaw-setup)\\.(zip|exe|dmg)",
            "score": 50,
            "desc": "匹配 ClawHavoc 恶意活动中的假安装程序。",
            "mitre": "T1204.002 - User Execution: Malicious File"
        }
    ],
    "high_patterns": [
        {
            "id": "H01",
            "name": "可疑二进制下载",
            "pattern": "download.*\\.(exe|dmg|pkg|deb|rpm|msi|apk|appimage)",
            "score": 25,
            "desc": "要求下载可执行的二进制文件。"
        },
        {
            "id": "H02",
            "name": "SSH 密钥操作",
            "pattern": "~/.ssh|id_rsa|id_ed25519|ssh-keygen|ssh-add",
            "score": 30,
            "desc": "试图访问或操作 SSH 密钥。"
        },
        {
            "id": "H03",
            "name": "加密货币钱包路径",
            "pattern": "\\.bitcoin|\\.ethereum|wallet\\.dat|keystore|metamask|solana|phantom",
            "score": 35,
            "desc": "试图访问加密货币钱包文件或路径。"
        },
        {
            "id": "H04",
            "name": "环境变量窃取",
            "pattern": "os\\.environ|process\\.env\\[|printenv|\\$\\{?[A-Z_]*(?:KEY|TOKEN|SECRET|PASSWORD)",
            "score": 25,
            "desc": "试图读取或导出包含 API Key 等敏感信息的环境变量。"
        },
        {
            "id": "H05",
            "name": "定时任务注入",
            "pattern": "crontab|systemctl\\s+enable|launchctl\\s+load|at\\s+\\d|schtasks",
            "score": 30,
            "desc": "试图建立持久化的定时任务或服务。"
        },
        {
            "id": "H06",
            "name": "DNS 隧道 / 数据外泄",
            "pattern": "dig\\s+.*TXT|nslookup.*\\||dns.*exfil|transfer.*covert",
            "score": 30,
            "desc": "可能通过 DNS 隧道进行隐蔽的数据外泄。"
        },
        {
            "id": "H07",
            "name": "进程注入 / 监控逃逸",
            "pattern": "ptrace|LD_PRELOAD|DYLD_INSERT|process_vm_writev|kill\\s+-9",
            "score": 30,
            "desc": "试图注入其他进程或逃避安全监控。"
        }
    ],
    "medium_patterns": [
        {
            "id": "M01",
            "name": "文件系统写操作",
            "pattern": "writeFile|createWriteStream|fs\\.write|open\\(.*['\"]w['\"]|>\\s*/",
            "score": 10,
            "desc": "执行文件系统写入操作。"
        },
        {
            "id": "M02",
            "name": "网络监听端口",
            "pattern": "listen\\(\\d|createServer|net\\.Server|socket\\.bind|INADDR_ANY",
            "score": 15,
            "desc": "创建网络服务器或监听端口。"
        },
        {
            "id": "M03",
            "name": "子进程生成",
            "pattern": "child_process|subprocess\\.Popen|subprocess\\.run|os\\.system\\(|os\\.popen",
            "score": 12,
            "desc": "调用底层 OS 生成子进程执行命令。"
        },
        {
            "id": "M04",
            "name": "文件权限修改",
            "pattern": "chmod\\s+[0-7]{3,4}|chmod\\s+\\+x|chown|chgrp",
            "score": 10,
            "desc": "修改文件权限，可能为后续执行做准备。"
        },
        {
            "id": "M05",
            "name": "压缩 / 打包操作",
            "pattern": "tar\\s+[cxz]|zip\\s+-r|gzip|7z\\s+a|rar\\s+a",
            "score": 8,
            "desc": "打包文件可能是数据外泄的前置步骤。"
        }
    ],
    "social_engineering": [
        {
            "id": "S01",
            "name": "紧迫催促语言",
            "pattern": "(install immediately|urgent|limited time|act now|hurry|立即安装|紧急)",
            "score": 10,
            "desc": "使用紧迫语气催促用户安装，属于社会工程学手段。"
        },
        {
            "id": "S02",
            "name": "虚假权威声明",
            "pattern": "(official openclaw|verified by anthropic|endorsed by|approved by|官方认证|官方推荐)",
            "score": 15,
            "desc": "冒充官方或权威机构提供虚假背书。"
        },
        {
            "id": "S03",
            "name": "恐吓战术",
            "pattern": "(security risk|vulnerability|exploit|hack|breach).{0,30}(without this|if you don't|必须安装)",
            "score": 12,
            "desc": "使用恐吓语言迫使用户安装。"
        }
    ],
    "whitelist": {
        "safe_domains": [
            "github.com",
            "npmjs.com",
            "npmjs.org",
            "pypi.org",
            "crates.io",
            "anthropic.com",
            "openclaw.ai",
            "clawhub.ai",
            "google.com",
            "apple.com",
            "microsoft.com",
            "docker.com",
            "hub.docker.com"
        ],
        "safe_bins": [
            "git",
            "node",
            "npm",
            "npx",
            "python3",
            "pip",
            "cargo",
            "go",
            "docker",
            "kubectl",
            "ls",
            "grep",
            "cat",
            "echo",
            "jq",
            "sed",
            "awk"
        ]
    }
}